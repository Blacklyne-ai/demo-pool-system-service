---
// Vertrauen: ECHTE Google-Bewertung (4,3) + belegte Credentials.
// Keine erfundenen Rezensionstexte - die Google-Listung hat öffentlich keine.
import Icon from './Icon.astro';
import { site, telMobile } from '../data/site';

const credentials = [
  { icon: 'ShieldCheck', title: 'TÜV-geprüft', note: 'seit 2004' },
  { icon: 'Award', title: 'Familienbetrieb', note: 'gegründet 1991' },
  { icon: 'Droplets', title: 'Wasseranalyse', note: 'Partner Gesundheitsamt München' },
  { icon: 'Microscope', title: 'Mikrobiologie', note: 'mit dem Institut Fresenius' },
];
---
<section class="section-foam py-20 md:py-28 relative overflow-hidden">
  <div class="mesh" aria-hidden="true"></div>
  <div class="container-px relative">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <!-- Echte Google-Bewertung -->
      <div class="lg:col-span-5 fade-in">
        <span class="eyebrow mb-5">Stimmen & Vertrauen</span>
        <h2 class="heading-lg text-balance mb-6">Bewertet auf <span class="accent-serif accent-water">Google.</span></h2>
        <div class="card lg-panel !p-7 flex items-center gap-6">
          <div class="text-center flex-shrink-0">
            <div class="big-number text-aqua-deep !text-5xl leading-none">{site.googleRating}</div>
            <div class="stars justify-center mt-2" role="img" aria-label={`${site.googleRating} von 5 Sternen`}>
              {Array.from({ length: 5 }).map(() => <Icon name="Star" size={16} strokeWidth={0} />)}
            </div>
            <div class="text-[0.72rem] text-muted-light font-mono mt-1.5">von 5</div>
          </div>
          <div class="border-l border-line pl-6">
            <div class="flex items-center gap-2 font-display font-bold text-ink mb-1">
              <Icon name="MapPin" size={16} strokeWidth={2.2} class="text-aqua-deep" /> Google-Bewertung
            </div>
            <p class="text-[0.92rem] text-muted text-pretty">Echte Bewertungen unserer Kundinnen und Kunden - lesen Sie selbst nach oder hinterlassen Sie Ihre.</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 mt-5">
          <a href={site.googleReviewsUrl} target="_blank" rel="noopener" class="btn btn-marine">
            <Icon name="Star" size={15} strokeWidth={2.2} /> Auf Google ansehen
          </a>
          <a href={telMobile} class="btn btn-outline"><Icon name="Phone" size={15} strokeWidth={2.2} />{site.phoneMobile}</a>
        </div>
      </div>

      <!-- Belegte Credentials -->
      <div class="lg:col-span-7 fade-in stagger-1">
        <p class="text-[0.8rem] font-mono uppercase tracking-[0.18em] text-muted-light mb-5">Worauf Sie sich verlassen können</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {credentials.map((c, i) => (
            <div class={`tile !flex-row items-center gap-4 stagger-${i + 1}`}>
              <span class="tile-icon tile-icon-marine flex-shrink-0"><Icon name={c.icon} size={22} strokeWidth={2} /></span>
              <div>
                <div class="font-display font-bold text-ink leading-snug">{c.title}</div>
                <div class="text-[0.85rem] text-muted">{c.note}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
