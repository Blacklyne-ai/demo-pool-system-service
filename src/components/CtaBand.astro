---
// Finales CTA-Band (Dark). Footer bleibt Info-only - keine doppelten CTAs.
import Icon from './Icon.astro';
import { site, telMobile, mailFor, whatsappLink } from '../data/site';
interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Fragen rund um Ihr <em>Schwimmbad?</em>',
  text = site.cta, // „Rufen Sie uns an, wir beraten Sie gerne vor Ort!"
} = Astro.props;
---
<div class="ripple-divider ripple-divider-dark" aria-hidden="true"></div>
<section class="section-marine aqua-horizon py-20 md:py-24 relative overflow-hidden">
  <div class="caustics caustics-soft" aria-hidden="true"></div>
  <span class="ghost-mark ghost-mark-light -right-10 -bottom-24" data-text="MEER" data-parallax="0.07" aria-hidden="true"></span>
  <div class="glow-orb" style="width: 460px; height: 460px; top: -180px; right: 4%; background: rgb(64 207 224); opacity: 0.12;" aria-hidden="true"></div>

  <div class="container-px relative">
    <div class="max-w-3xl fade-in">
      <span class="eyebrow eyebrow-light mb-5 inline-flex items-center gap-3">
        <span class="dot dot-aqua" aria-hidden="true"></span>
        Beratung anfragen
      </span>
      <h2 class="heading-lg text-white text-balance mb-5 section-title" set:html={title} />
      <p class="text-xl text-white/75 leading-relaxed mb-8 max-w-2xl text-pretty">{text}</p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-3">
        <a href={telMobile} class="btn btn-aqua btn-lg">
          <Icon name="Phone" size={17} strokeWidth={2.3} />
          {site.phoneMobile}
        </a>
        <a href={mailFor('Anfrage rund ums Schwimmbad')} class="btn btn-ghost btn-lg">
          <Icon name="Mail" size={17} strokeWidth={2.2} />
          Nachricht schreiben
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
          <Icon name="MessageCircle" size={18} strokeWidth={2.2} />
          WhatsApp
        </a>
      </div>
      <p class="text-sm text-white/45 mt-6 flex items-center gap-2">
        <Icon name="MapPin" size={15} strokeWidth={2} />
        {site.address.street}, {site.address.postcode} {site.address.city}
      </p>
    </div>
  </div>
</section>
