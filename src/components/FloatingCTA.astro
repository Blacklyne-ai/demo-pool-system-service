---
// Mobile Floating-Bar — bewusst schlank (keine fetten Controls).
import { telMobile, whatsappLink, site } from '../data/site';
import Icon from './Icon.astro';
---
<div class="floating-mobile fixed bottom-3 left-0 right-0 z-40 px-3 gap-2 pointer-events-none">
  <a href={telMobile} class="btn btn-marine pointer-events-auto flex-1" aria-label={`Anrufen ${site.phoneMobile}`}>
    <Icon name="Phone" size={15} strokeWidth={2.3} />
    <span class="text-[0.8rem] mono">Anrufen</span>
  </a>
  <a href="/kontakt" class="btn btn-light pointer-events-auto flex-1" aria-label="Beratung anfragen">
    Beratung
  </a>
  <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp pointer-events-auto !px-3.5" aria-label="WhatsApp schreiben">
    <Icon name="MessageCircle" size={18} strokeWidth={2.2} />
  </a>
</div>
