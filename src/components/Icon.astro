---
// Zentrale Lucide-Icon-Map (@lucide/astro, named imports).
// Data-Files referenzieren Icons per Name; alles Verwendete steht hier.
// Brand-Icons (z. B. Instagram) gibt es in Lucide NICHT → inline SVG.
import {
  WavesLadder, Droplets, Sun, Funnel, Gauge, Bot, HardHat, Construction,
  Sparkles, SprayCan, Recycle, Repeat, Wind, Microscope, Thermometer, ThermometerSun,
  Snowflake, Sailboat, Leaf, Waypoints,
  ShieldCheck, BadgeCheck, Award, HeartHandshake, Users, Building2,
  Phone, Mail, MapPin, MessageCircle, Navigation, Wrench,
  ArrowRight, ArrowUpRight, Check, ChevronRight, ChevronDown,
  Star, Quote, Clock, CalendarCheck, X, Menu, Info, CircleDot,
} from '@lucide/astro';

const MAP: Record<string, any> = {
  WavesLadder, Droplets, Sun, Funnel, Gauge, Bot, HardHat, Construction,
  Sparkles, SprayCan, Recycle, Repeat, Wind, Microscope, Thermometer, ThermometerSun,
  Snowflake, Sailboat, Leaf, Waypoints,
  ShieldCheck, BadgeCheck, Award, HeartHandshake, Users, Building2,
  Phone, Mail, MapPin, MessageCircle, Navigation, Wrench,
  ArrowRight, ArrowUpRight, Check, ChevronRight, ChevronDown,
  Star, Quote, Clock, CalendarCheck, X, Menu, Info, CircleDot,
};

interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
const Cmp = MAP[name] ?? CircleDot;
---
<Cmp size={size} class={className} stroke-width={strokeWidth} />
