---
// Interaktiver Concierge „Wobei dürfen wir helfen?" - Problem anklicken,
// passende Lösung erscheint. Alles auf belegte Leistungen gemappt.
import Icon from './Icon.astro';
import { concierge } from '../data/interactive';
import { telMobile, site } from '../data/site';
---
<section id="hilfe" class="section-paper py-20 md:py-28 relative overflow-hidden scroll-mt-24">
  <div class="caustics caustics-soft" aria-hidden="true"></div>
  <div class="container-px relative">
    <div class="max-w-2xl mb-10 fade-in">
      <span class="eyebrow mb-5">Interaktiv · Ihr Anliegen</span>
      <h2 class="heading-lg text-balance">Wobei dürfen wir <span class="accent-serif accent-water">helfen?</span></h2>
      <p class="text-lg text-muted mt-4 text-pretty">Wählen Sie Ihr Anliegen - wir zeigen Ihnen direkt, wie wir es lösen.</p>
    </div>

    <div class="grid lg:grid-cols-5 gap-6 lg:gap-8 items-start">
      <!-- Fragen -->
      <div class="lg:col-span-2 flex flex-col gap-2.5 fade-in" role="tablist" aria-label="Anliegen wählen">
        {concierge.map((c, i) => (
          <button class={`concierge-q ${i === 0 ? 'is-active' : ''}`} data-q={i} role="tab" aria-selected={i === 0 ? 'true' : 'false'} aria-controls={`answer-${i}`}>
            <span class="cq-icon"><Icon name={c.icon} size={18} strokeWidth={2} /></span>
            <span class="font-display font-semibold text-[0.96rem] text-left">{c.q}</span>
            <Icon name="ChevronRight" size={16} strokeWidth={2.4} class="cq-chev ml-auto flex-shrink-0" />
          </button>
        ))}
      </div>

      <!-- Antworten -->
      <div class="lg:col-span-3 fade-in stagger-1">
        {concierge.map((c, i) => (
          <div id={`answer-${i}`} class="concierge-a lg lg-dark lg-strong rounded-[24px] p-7 md:p-9 overflow-hidden" data-q={i} role="tabpanel" hidden={i !== 0}>
            <div>
              <span class="tile-icon mb-5 !bg-white/10 !border-white/15 !text-aqua-bright"><Icon name={c.icon} size={26} strokeWidth={1.9} /></span>
              <h3 class="text-white font-display font-extrabold text-2xl mb-3">{c.answerTitle}</h3>
              <p class="text-white/75 leading-relaxed text-pretty mb-7">{c.answer}</p>
              <div class="flex flex-col sm:flex-row gap-3">
                <a href={`/leistungen#${c.slug}`} class="btn btn-aqua">{c.cta}<Icon name="ArrowRight" size={15} strokeWidth={2.4} /></a>
                <a href={telMobile} class="btn btn-ghost"><Icon name="Phone" size={15} strokeWidth={2.2} />{site.phoneMobile}</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .concierge-q {
    display: flex; align-items: center; gap: 0.85rem; width: 100%;
    padding: 0.95rem 1.1rem; border-radius: 16px;
    background: #fff; border: 1px solid rgb(var(--rgb-border));
    color: rgb(var(--rgb-ink) / 0.78); transition: all 0.25s ease;
    cursor: pointer; -webkit-tap-highlight-color: transparent;
  }
  .concierge-q:hover { border-color: rgb(var(--rgb-aqua) / 0.5); transform: translateX(3px); }
  .cq-icon {
    width: 38px; height: 38px; border-radius: 11px; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgb(var(--rgb-aqua) / 0.1); color: rgb(var(--rgb-aqua-deep));
    border: 1px solid rgb(var(--rgb-aqua) / 0.18); transition: all 0.25s ease;
  }
  .cq-chev { color: rgb(var(--rgb-ink) / 0.3); transition: all 0.25s ease; }
  .concierge-q.is-active {
    background: rgb(var(--rgb-aqua-deep)); border-color: rgb(var(--rgb-aqua-deep)); color: #fff;
    box-shadow: 0 12px 26px -12px rgb(11 110 124 / 0.6);
  }
  .concierge-q.is-active .cq-icon { background: rgb(255 255 255 / 0.16); color: #fff; border-color: rgb(255 255 255 / 0.2); }
  .concierge-q.is-active .cq-chev { color: #fff; transform: translateX(3px); }
  .concierge-a[hidden] { display: none; }
  .concierge-a:not([hidden]) { animation: panel-in 0.45s cubic-bezier(0.16,1,0.3,1); }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const qs = document.querySelectorAll<HTMLButtonElement>('.concierge-q');
    const as = document.querySelectorAll<HTMLElement>('.concierge-a');
    if (!qs.length) return;
    qs.forEach((q) => {
      const show = () => {
        const id = q.dataset.q;
        qs.forEach((x) => { const on = x === q; x.classList.toggle('is-active', on); x.setAttribute('aria-selected', on ? 'true' : 'false'); });
        as.forEach((a) => { a.hidden = a.dataset.q !== id; });
      };
      q.addEventListener('click', show);
      q.addEventListener('mouseenter', show);
    });
  });
</script>
