---
// Interaktive Geschichte „Ihr Pool durchs Jahr" - Saison-Tabs + Panel-Wechsel.
import Icon from './Icon.astro';
import { seasons } from '../data/interactive';
const DEFAULT = 1; // Sommer
---
<section id="saison" class="section-foam py-20 md:py-28 relative overflow-hidden scroll-mt-24">
  <span class="ghost-mark -left-12 -bottom-20 opacity-40" data-text="JAHR" data-parallax="0.05" aria-hidden="true"></span>
  <div class="container-px relative">
    <div class="max-w-2xl mb-10 fade-in">
      <span class="eyebrow mb-5">Interaktiv · Ihr Pool durchs Jahr</span>
      <h2 class="heading-lg text-balance">Ein Becken, <span class="accent-serif accent-water">vier Jahreszeiten.</span></h2>
      <p class="text-lg text-muted mt-4 text-pretty">Klicken Sie sich durchs Jahr - und sehen Sie, worum wir uns wann für Sie kümmern.</p>
    </div>

    <!-- Glas-Segment-Control -->
    <div class="overflow-x-auto pb-2 -mx-1 px-1 fade-in">
      <div class="seg" data-seg role="tablist" aria-label="Jahreszeit wählen">
        <span class="seg-thumb" aria-hidden="true"></span>
        {seasons.map((s, i) => (
          <button
            class={`seg-btn season-tab ${i === DEFAULT ? 'is-active' : ''}`}
            data-season={s.id}
            role="tab"
            aria-selected={i === DEFAULT ? 'true' : 'false'}
            aria-controls={`panel-${s.id}`}
          >
            <Icon name={s.icon} size={17} strokeWidth={2} />
            <span class="flex flex-col items-start leading-none">
              <span class="font-bold">{s.label}</span>
              <span class="text-[0.62rem] font-mono opacity-70 mt-0.5">{s.months}</span>
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- Panels -->
    <div class="mt-7">
      {seasons.map((s, i) => (
        <div id={`panel-${s.id}`} class="season-panel" data-season={s.id} role="tabpanel" hidden={i !== DEFAULT}>
          <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
            <div class="photo-frame order-1 lg:order-none" data-tilt="2.5">
              <picture>
                {s.imageWebp && <source type="image/webp" srcset={s.imageWebp} />}
                <img src={s.image} alt={s.imageAlt} width="1000" height="667" class="w-full aspect-[3/2] object-cover" loading="lazy" />
              </picture>
              {s.real && <span class="absolute top-3 left-3 pill pill-dark !text-[0.6rem]">Echtes Kundenfoto</span>}
            </div>
            <div>
              <div class="flex items-center gap-2.5 mb-3">
                <span class="tile-icon tile-icon-marine !w-11 !h-11"><Icon name={s.icon} size={20} strokeWidth={2} /></span>
                <span class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-aqua-deep">{s.label} · {s.months}</span>
              </div>
              <h3 class="heading-md mb-3">{s.title}</h3>
              <p class="text-muted leading-relaxed text-pretty mb-5">{s.text}</p>
              <ul class="space-y-2.5 mb-7">
                {s.jobs.map((j) => (
                  <li class="flex items-center gap-3 text-ink">
                    <span class="w-6 h-6 rounded-full bg-aqua/10 border border-aqua/25 flex items-center justify-center flex-shrink-0">
                      <Icon name="Check" size={13} strokeWidth={2.8} class="text-aqua-deep" />
                    </span>
                    <span class="font-display font-semibold text-[0.98rem]">{j}</span>
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-2.5">
                {s.links.map((l) => (
                  <a href={`/leistungen#${l.slug}`} class="tag">{l.label}<Icon name="ArrowUpRight" size={14} strokeWidth={2.4} class="text-aqua-deep" /></a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .season-panel[hidden] { display: none; }
  .season-panel:not([hidden]) { animation: panel-in 0.5s cubic-bezier(0.16,1,0.3,1); }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.season-tab');
    const panels = document.querySelectorAll<HTMLElement>('.season-panel');
    if (!tabs.length) return;
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.season;
        tabs.forEach((t) => { const on = t === tab; t.classList.toggle('is-active', on); t.setAttribute('aria-selected', on ? 'true' : 'false'); });
        panels.forEach((p) => { p.hidden = p.dataset.season !== id; });
      });
    });
  });
</script>
