---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const toc = [
  { id: 'verantwortlicher', n: '1', icon: 'ShieldCheck', label: 'Verantwortlicher' },
  { id: 'hosting', n: '2', icon: 'Building2', label: 'Hosting' },
  { id: 'kontakt', n: '3', icon: 'MessageCircle', label: 'Kontaktaufnahme' },
  { id: 'maps', n: '4', icon: 'MapPin', label: 'Google Maps' },
  { id: 'cookies', n: '5', icon: 'Info', label: 'Cookies' },
  { id: 'rechte', n: '6', icon: 'BadgeCheck', label: 'Ihre Rechte' },
  { id: 'ssl', n: '7', icon: 'Check', label: 'SSL-/TLS-Verschlüsselung' },
];
---

<Layout title="Datenschutzerklärung · Pool-System-Service" current="/datenschutz" noindex={true}>
  <PageHero eyebrow="Rechtliches" crumb="Datenschutz" title="Datenschutz&shy;erklärung" ghost="DSGVO" />

  <section class="section-paper py-14 md:py-20 relative overflow-hidden">
    <div class="mesh" aria-hidden="true"></div>
    <div class="container-px relative">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-10 items-start">
        <!-- TOC (Glas, sticky, Scroll-Spy) -->
        <aside class="lg:col-span-4 lg:sticky lg:top-28 fade-in">
          <div class="lg lg-light rounded-[24px] p-5">
            <div class="eyebrow mb-4 !text-[0.66rem]">Inhalt</div>
            <nav class="flex flex-col gap-0.5" aria-label="Abschnitte">
              {toc.map((t) => (
                <a href={`#${t.id}`} class="ds-toc-link" data-spy={t.id}>
                  <span class="ds-toc-ico"><Icon name={t.icon} size={15} strokeWidth={2.2} /></span>
                  <span class="text-[0.92rem] font-display font-semibold">{t.label}</span>
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- Inhalt (Glas) -->
        <div class="lg:col-span-8 fade-in stagger-1">
          <div class="lg lg-light rounded-[24px] p-7 md:p-10">
            <p class="text-muted leading-relaxed text-pretty mb-2">
              Der Schutz Ihrer persönlichen Daten ist uns wichtig. Wir behandeln Ihre personenbezogenen
              Daten vertraulich und entsprechend der gesetzlichen Datenschutzvorschriften (DSGVO, BDSG)
              sowie dieser Datenschutzerklärung. Diese Website nutzt keine Tracking-Cookies und keine
              Analyse-Dienste.
            </p>

            <div class="legal-prose">
              <section id="verantwortlicher" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="ShieldCheck" size={16} strokeWidth={2.2} /></span>1. Verantwortlicher</h2>
                <div class="lg lg-aqua rounded-2xl p-5 not-prose">
                  <p class="!mb-0 text-ink">
                    <strong>Pool-System-Service</strong>, Inhaberin {site.owner}<br />
                    {site.address.street}, {site.address.postcode} {site.address.city}<br />
                    Telefon: {site.phoneMobile} · {site.phoneLandline}<br />
                    E-Mail: {site.email}
                  </p>
                </div>
              </section>

              <section id="hosting" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="Building2" size={16} strokeWidth={2.2} /></span>2. Hosting</h2>
                <p>
                  Diese Website wird als statische Seite bei einem Hosting-Dienstleister gehostet. Beim Aufruf
                  der Seite werden technisch notwendige Daten (z. B. IP-Adresse, Datum und Uhrzeit des Abrufs,
                  Browsertyp) in Server-Logfiles verarbeitet, um die Auslieferung der Seite und die Sicherheit
                  des Systems zu gewährleisten. Rechtsgrundlage ist Art. 6 Abs. 1 lit. f DSGVO (berechtigtes
                  Interesse an einem sicheren, störungsfreien Betrieb).
                </p>
              </section>

              <section id="kontakt" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="MessageCircle" size={16} strokeWidth={2.2} /></span>3. Kontaktaufnahme</h2>
                <p>
                  Wenn Sie uns per Telefon, E-Mail oder WhatsApp kontaktieren, werden Ihre Angaben zur
                  Bearbeitung der Anfrage und für den Fall von Anschlussfragen gespeichert. Rechtsgrundlage ist
                  Art. 6 Abs. 1 lit. b DSGVO (Anbahnung/Erfüllung eines Vertrags) bzw. lit. f DSGVO
                  (berechtigtes Interesse an der Beantwortung Ihrer Anfrage). Diese Daten geben wir nicht ohne
                  Ihre Einwilligung weiter.
                </p>
                <h3>Hinweis zu WhatsApp</h3>
                <p>
                  Nutzen Sie den WhatsApp-Kontakt, gelten zusätzlich die Datenschutzbestimmungen der WhatsApp
                  Ireland Ltd. Bei der Kommunikation über WhatsApp können Daten an Server außerhalb der EU
                  übertragen werden. Wenn Sie das vermeiden möchten, nutzen Sie bitte Telefon oder E-Mail.
                </p>
              </section>

              <section id="maps" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="MapPin" size={16} strokeWidth={2.2} /></span>4. Google Maps</h2>
                <p>
                  Zur Darstellung unseres Standorts binden wir Karten des Dienstes Google Maps (Google Ireland
                  Limited) ein. Beim Laden der Karte kann Ihre IP-Adresse an Google übertragen werden.
                  Rechtsgrundlage ist Art. 6 Abs. 1 lit. f DSGVO (ansprechende Darstellung und einfache
                  Auffindbarkeit). Weitere Informationen finden Sie in der Datenschutzerklärung von Google:
                  <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">https://policies.google.com/privacy</a>.
                </p>
              </section>

              <section id="cookies" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="Info" size={16} strokeWidth={2.2} /></span>5. Cookies</h2>
                <p>
                  Diese Website setzt lediglich ein technisch notwendiges Speicherelement (localStorage), um
                  sich zu merken, dass Sie den Cookie-Hinweis geschlossen haben. Es findet kein Tracking statt,
                  und es werden keine Profile gebildet.
                </p>
              </section>

              <section id="rechte" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="BadgeCheck" size={16} strokeWidth={2.2} /></span>6. Ihre Rechte</h2>
                <p>Sie haben jederzeit das Recht auf:</p>
                <ul>
                  <li>Auskunft über die zu Ihrer Person gespeicherten Daten (Art. 15 DSGVO)</li>
                  <li>Berichtigung unrichtiger Daten (Art. 16 DSGVO)</li>
                  <li>Löschung (Art. 17 DSGVO) und Einschränkung der Verarbeitung (Art. 18 DSGVO)</li>
                  <li>Datenübertragbarkeit (Art. 20 DSGVO)</li>
                  <li>Widerspruch gegen die Verarbeitung (Art. 21 DSGVO)</li>
                </ul>
                <p>
                  Zudem haben Sie das Recht, sich bei einer Datenschutz-Aufsichtsbehörde zu beschweren. Zur
                  Geltendmachung Ihrer Rechte genügt eine Nachricht an die oben genannten Kontaktdaten.
                </p>
              </section>

              <section id="ssl" class="scroll-mt-28">
                <h2 class="ds-h"><span class="ds-ico"><Icon name="Check" size={16} strokeWidth={2.6} /></span>7. SSL-/TLS-Verschlüsselung</h2>
                <p>
                  Diese Seite nutzt aus Sicherheitsgründen eine SSL-/TLS-Verschlüsselung. Eine verschlüsselte
                  Verbindung erkennen Sie am „https://" in der Adresszeile Ihres Browsers.
                </p>
              </section>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Fragen zum Datenschutz? <em>Sprechen Sie uns an.</em>" />
</Layout>

<style>
  .ds-toc-link { display: flex; align-items: center; gap: 0.7rem; padding: 0.55rem 0.7rem; border-radius: 12px; color: rgb(var(--rgb-ink) / 0.65); transition: all 0.2s ease; }
  .ds-toc-link:hover { background: rgb(var(--rgb-aqua) / 0.08); color: rgb(var(--rgb-ink)); }
  .ds-toc-link.active { background: rgb(var(--rgb-aqua) / 0.12); color: rgb(var(--rgb-aqua-deep)); }
  .ds-toc-ico { width: 26px; height: 26px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; background: rgb(var(--rgb-aqua) / 0.1); color: rgb(var(--rgb-aqua-deep)); flex-shrink: 0; transition: all 0.2s ease; }
  .ds-toc-link.active .ds-toc-ico { background: rgb(var(--rgb-aqua-deep)); color: #fff; }
  .legal-prose .ds-h { display: flex; align-items: center; gap: 0.7rem; }
  .ds-ico { width: 30px; height: 30px; border-radius: 9px; display: inline-flex; align-items: center; justify-content: center; background: rgb(var(--rgb-aqua) / 0.1); color: rgb(var(--rgb-aqua-deep)); flex-shrink: 0; }
  .not-prose p { margin: 0 !important; }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const links = document.querySelectorAll<HTMLElement>('.ds-toc-link');
    if (!links.length) return;
    const map = new Map<string, HTMLElement>();
    links.forEach((l) => map.set(l.dataset.spy || '', l));
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            map.get(e.target.id)?.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
    );
    document.querySelectorAll('section[id]').forEach((s) => spy.observe(s));
  });
</script>
